<script>
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  let lightbox: ReturnType<typeof GLightbox> | undefined;

  function initGallery() {
    const content = document.querySelector('.markdown-content');
    if (!content) return;

    content.querySelectorAll<HTMLImageElement>('.gallery-item__image').forEach((img) => {
      if (img.classList.contains('glightbox')) return;

      img.classList.add('glightbox');
      img.dataset.type = 'image';
      img.dataset.gallery = 'post-inline-gallery';
      img.dataset.description = img.alt;
    });

    lightbox?.destroy();

    lightbox = GLightbox({
      selector: '.markdown-content .gallery-item__image.glightbox',
      touchNavigation: true,
      loop: true,
      autoplayVideos: false,
      keyboardNavigation: true,
      closeButton: true,
    });
  }

  document.addEventListener('DOMContentLoaded', initGallery);
  document.addEventListener('astro:page-load', initGallery);
</script>