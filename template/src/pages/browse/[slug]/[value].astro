---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import Section from "@/components/Section.astro";
import PostFeed from "@/components/Feed.astro";
import NoteFeed from "@/components/NoteFeed.astro";
import { getAllEntries } from "@/utils/content";
import {
  getBrowseValues,
  filterBrowseEntries,
} from "@/utils/browse";

import { getBrowseDimensions } from "@/utils/browse";

const entries = await getAllEntries();

export async function getStaticPaths() {
  const entries = await getAllEntries();
  const dimensions = await getBrowseDimensions();
  return dimensions.flatMap((dimension) =>
    getBrowseValues(entries, dimension.key).map((value) => ({
      params: {
        slug: dimension.slug,
        value: value.slug,
      },
      props: {
        dimension,
        browseValue: value,
      },
    })),
  );
}

const {
  dimension,
  browseValue,
} = Astro.props;

const filteredEntries = filterBrowseEntries(
  entries,
  dimension.key,
  browseValue.slug,
);

const posts = filteredEntries.filter((entry) => entry.collection === "posts");
const notes = filteredEntries.filter((entry) => entry.collection === "notes");
---

<BaseLayout
  title={browseValue.value}
  description={`${filteredEntries.length} entries`}
>
  <div class="page-width">
    <PageHeader
      title={browseValue.value}
      lede={`Browse by ${dimension.title}`}
    />

    {posts.length > 0 && (
      <Section title="Posts">
        <PostFeed entries={posts} />
      </Section>
    )}

    {notes.length > 0 && (
      <Section title="Notes">
        <NoteFeed entries={notes} />
      </Section>
    )}
  </div>

</BaseLayout>