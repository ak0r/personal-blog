---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import Section from "@/components/Section.astro";
import Feed from "@/components/Feed.astro";
import NotesFeed from "@/components/NoteFeed.astro";
import StructuredData from "@/components/StructuredData.astro";
import { getConfig } from "@/utils/config";
import { getAllPosts, getAllNotes } from "@/utils/content";
import { absoluteUrl } from "@/utils/url";

const siteConfig = await getConfig();
const allPosts = await getAllPosts();
const allNotes = await getAllNotes();

const recentPosts = allPosts.slice(0, siteConfig.recentPosts);
const recentNotes = allNotes.slice(0, siteConfig.recentPosts);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.title,
  description: siteConfig.description,
  url: absoluteUrl("/", Astro.site),
  author: { "@type": "Person", name: siteConfig.author.name, url: siteConfig.author.url },
};
---
<BaseLayout>
  <StructuredData schema={schema} slot="head" />
  <div class="page-width">
    <PageHeader
      title={siteConfig.title}
      lede={siteConfig.heroText}
    />
    <Section title="Recent Writing" href="/posts" action="View All">
      <Feed entries={recentPosts} />
    </Section>

    <Section title="Recent Notes" href="/notes" action="View All">
      <NotesFeed entries={recentNotes} />
    </Section>
  </div>
</BaseLayout>