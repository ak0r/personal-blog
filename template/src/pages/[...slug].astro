---
import { render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { getAllPages, getPageSlugPath } from "@/utils/content";

export async function getStaticPaths() {
  const pages = await getAllPages();

  return pages.map((page) => ({
    params: { slug: getPageSlugPath(page.id, page.filePath) },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<BaseLayout title={page.data.title}>
  <div class="page-width">
    <PageHeader title={page.data.title} lede={page.data.description} />

    <article data-pagefind-body class="markdown-content py-6">
      <meta data-pagefind-meta="title[content]" content={page.data.title} />
      <meta data-pagefind-sort="date[content]" content={page.data.updated?.toISOString()} />
      <Content />
    </article>
  </div>
</BaseLayout>
