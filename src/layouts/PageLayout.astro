---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SEO from "@/components/SEO.astro";
import ContentHeader from "@/components/ContentHeader.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";

interface Props {
  entry: CollectionEntry<"pages">;
}

const { entry } = Astro.props;
const { title, description, updated } = entry.data;

const formattedDate = updated?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
});
---

<BaseLayout>
  <SEO slot="seo" {title} description={description ?? ""} />
  <Fragment slot="header">
    <Breadcrumb label={title} />
    <ContentHeader {title}>
      {updated && (
        <span slot="meta">Updated {formattedDate}</span>
      )}
    </ContentHeader>
  </Fragment>
  
  <Fragment>
    <slot />
  </Fragment>

  <!-- navigation and after slots unused for static pages -->
</BaseLayout>