---
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";
import { Picture } from 'astro:assets';
import BaseLayout from "@/layouts/BaseLayout.astro";
import SEO from "@/components/SEO.astro";
import SchemaOrg from "@/components/SchemaOrg.astro";
import ContentHeader from "@/components/ContentHeader.astro";
import PostMeta from "@/components/PostMeta.astro";
import PostNav from "@/components/PostNav.astro";
import PostItem from "@/components/PostItem.astro";
import SeriesNav from "@/components/SeriesNav.astro";
import CopyMarkdown from "@/components/CopyMarkdown.astro";
import Icon from "@/components/Icon.astro";
import {
  getPublishedPosts,
  getSeriesPosts,
  getRelatedPosts,
  calculateReadingTime,
  getPostUrl,
  toDestinationId,
} from "@/utils/content.utils";
import { getGalleryImages, getCoverImage } from '@/utils/image.utils';
import PostGallery from '@/components/PostGallery.astro';
import { siteConfig } from "@/site.config";
import GalleryInit from '@/components/GalleryInit.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

interface Props {
  entry: CollectionEntry<"posts">;
}

const { entry } = Astro.props;
const {
  title,
  description,
  published,
  updated,
  tags,
  cover,
  series,
  category,
  countries,   // z.array(z.string()) — plain strings e.g. ["India", "Japan"]
  region,      // e.g. "Sahyadri"
  places,      // e.g. ["Rajgad", "Pune"]
} = entry.data;

// Primary country for display — first in list
const primaryCountry   = countries?.[0] ?? null;
const primaryCountryId = primaryCountry ? toDestinationId(primaryCountry) : null;

// Resolve destination entry for pagefind meta only
const destinationEntry = primaryCountryId
  ? await getEntry('destinations', primaryCountryId).catch(() => null)
  : null;

const allPosts      = await getPublishedPosts();
const related       = getRelatedPosts(entry, allPosts, siteConfig.relatedPosts);
const seriesPosts   = series ? await getSeriesPosts(series) : [];
const readTime      = calculateReadingTime(entry.body ?? "").text;
const galleryImages = getGalleryImages(entry.filePath);
const coverImage    = getCoverImage(cover);
const ogImage       = `/og/posts/${entry.id}.png`;

const currentIndex = allPosts.findIndex((p) => p.id === entry.id);
const prev = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const next = currentIndex > 0                   ? allPosts[currentIndex - 1] : null;

const canonicalPath = getPostUrl(entry);
---

<BaseLayout>
  <SEO
    slot="seo"
    {title}
    description={description ?? ""}
    type="article"
    publishedTime={published}
    {tags}
    {ogImage}
  />
  <SchemaOrg slot="seo" type="article" {entry} />

  <Fragment slot="header">
    <Breadcrumb label={title} />

    {/* ── Eyebrow ────────────────────────────────────────────────────────
        [India]  Sahyadri
        Only shown for travel posts with a country set.
    ─────────────────────────────────────────────────────────────────── */}
    {primaryCountry && (
      <div class="post-eyebrow">
        <a
          href={`/destinations/${primaryCountryId}/`}
          class="post-eyebrow__country badge badge--subtle badge--accent badge--country"
        >
          {primaryCountry}
        </a>
        {region && (
          <span class="post-eyebrow__region">{region}</span>
        )}
      </div>
    )}

    <ContentHeader {title} pagefind>
      <Fragment slot="meta">
        <PostMeta
          {published}
          {updated}
          {readTime}
          {tags}
          {places}
        />
      </Fragment>
    </ContentHeader>
  </Fragment>

  <Fragment>
    <aside data-pagefind-body>
      <meta data-pagefind-meta="title[content]" content={entry.data.title} />
      <meta data-pagefind-sort="date[content]" content={published.toISOString()} />
      <meta data-pagefind-filter="collection[content]" content={category} />
      {destinationEntry && (
        <meta data-pagefind-filter="destination[content]" content={destinationEntry.data.title} />
      )}
      {places?.map((place) => (
        <meta data-pagefind-filter="place[content]" content={place} />
      ))}
      {tags?.map((tag) => (
        <meta data-pagefind-filter="tag[content]" content={tag} />
      ))}

      {coverImage && (
        <figure class="post-cover">
          <Picture
            src={coverImage}
            alt={title}
            width={900}
            formats={['avif', 'webp']}
            loading="eager"
            decoding="async"
          />
        </figure>
      )}

      <section class="post-content" role="article">
        <slot />
      </section>

      {galleryImages.length > 0 && (
        <PostGallery images={galleryImages} galleryId={entry.id} />
      )}
    </aside>

    <CopyMarkdown />
  </Fragment>

  <Fragment slot="navigation">
    {seriesPosts.length > 1 && (
      <SeriesNav current={entry} posts={seriesPosts} />
    )}
    <PostNav {prev} {next} />
  </Fragment>

  <Fragment slot="after">
    {related.length > 0 && (
      <aside class="related-posts">
        <h2>Related Posts</h2>
        <div class="related-list">
          {related.map((post) => (
            <PostItem {post} />
          ))}
        </div>
      </aside>
    )}
  </Fragment>

  <GalleryInit slot="scripts" />
</BaseLayout>