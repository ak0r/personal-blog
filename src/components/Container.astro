---
interface Props {
  setWidth?: string;
  class?: string;
}

const { setWidth = 'md', class: className = '' } = Astro.props;

const contentWidth = setWidth;
const maxWidthMap: Record<string, string> = {
  'sm': 'max-w-(--breakpoint-sm)',
  'md': 'max-w-(--breakpoint-md)',
  'lg': 'max-w-(--breakpoint-lg)',
  'xl': 'max-w-(--breakpoint-xl)',
  '2xl': 'max-w-(--breakpoint-2xl)',
};
const maxWidthClass = maxWidthMap[contentWidth] || 'max-w-(--breakpoint-md)';
const allClasses = `relative container mx-auto px-4 sm:px-6 lg:px-8 w-full ${className} ${maxWidthClass}`.trim();

---

<div class={allClasses}>
  <slot />
</div>