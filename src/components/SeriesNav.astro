---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/content.utils";

interface Props {
  current: CollectionEntry<"posts">;
  posts:   CollectionEntry<"posts">[];
}

const { current, posts } = Astro.props;

const currentIndex = posts.findIndex((p) => p.id === current.id);
const prev = currentIndex > 0 ? posts[currentIndex - 1] : null;
const next = currentIndex < posts.length - 1 ? posts[currentIndex + 1] : null;
---

<nav class="series-nav" aria-label="Series navigation">
  <details>
    <summary class="series-nav__summary">
      <span class="series-nav__label">Series</span>
      <span class="series-nav__title">{current.data.series}</span>
      <span class="series-nav__count">{currentIndex + 1} of {posts.length}</span>
    </summary>

    <ol class="series-nav__list">
      {posts.map((post) => (
        <li class:list={[
          "card card--interactive card--padded series-nav__item",
          { "series-nav__item--current": post.id === current.id }
        ]}>
          {post.id === current.id ? (
            <span class="series-nav__item-title">{post.data.title}</span>
          ) : (
            <a href={getPostUrl(post)} class="series-nav__item-title">
              {post.data.title}
            </a>
          )}
        </li>
      ))}
    </ol>

    {(prev || next) && (
      <div class="series-nav__pagination">
        {prev && (
          <a href={getPostUrl(prev)} class="series-nav__link series-nav__link--prev">
            <span class="series-nav__link-label">← Previous</span>
            <span class="series-nav__link-title">{prev.data.title}</span>
          </a>
        )}
        {next && (
          <a href={getPostUrl(next)} class="series-nav__link series-nav__link--next">
            <span class="series-nav__link-label">Next →</span>
            <span class="series-nav__link-title">{next.data.title}</span>
          </a>
        )}
      </div>
    )}
  </details>
</nav>