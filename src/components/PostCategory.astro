---
/**
 * PostCategory.astro
 *
 * Category badge — rendered in the post eyebrow above the title.
 * Renders nothing if category is undefined.
 */

import Icon from '@/components/Icon.astro';

interface Props {
  category?: 'tech' | 'travel';
}

const { category } = Astro.props;

const colorMap: Record<string, string> = {
  travel: 'badge--olive',
  tech:   'badge--sky',
};

const iconMap: Record<string, 'compass' | 'cpu'> = {
  travel: 'compass',
  tech:   'cpu',
};
---

{category && (
  <span
    class={`badge badge--subtle badge--category ${colorMap[category]}`}
    aria-label={`Content category: ${category}`}
  >
    <Icon name={iconMap[category]} size={13} />
    {category}
  </span>
)}