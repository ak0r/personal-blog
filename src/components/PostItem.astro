---
/**
 * PostItem — a single post row in a list.
 *
 * Layout:  Title                    [Type/Tech]  March 2nd
 *
 * Travel posts: shows post type (Story, Guide, etc.) in olive
 * Tech posts:   shows "Tech" in sky
 * Both use .badge--subtle for consistent visual weight.
 */
import PostMeta from "@/components/PostMeta.astro";
import { getPostUrl, type AnyPost } from "@/utils/content.utils";

interface Props {
  post: AnyPost;
}

const { post } = Astro.props;
const href = getPostUrl(post);

const isTech   = post.collection === 'tech';
const postType = !isTech ? (post as any).data.type : undefined;

// Label and color per collection/type
const badgeLabel = isTech ? 'Tech' : postType
  ? postType.charAt(0).toUpperCase() + postType.slice(1)
  : null;

const badgeClass = isTech
  ? 'badge badge--subtle badge--sky'
  : 'badge badge--subtle badge--olive';
---

<div class="card card--interactive card--padded post-item">
  <a href={href} class="post-item__link">
    {post.data.title}
  </a>
  <div class="post-item__meta">
    {badgeLabel && (
      <span class={badgeClass}>{badgeLabel}</span>
    )}
    <PostMeta published={post.data.published} />
  </div>
</div>