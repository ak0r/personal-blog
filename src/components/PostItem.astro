---
/**
 * PostItem — a single post row in a list.
 *
 * Layout:  Title                    March 2nd
 *
 * Date is rendered without year or read time — PostMeta in list mode.
 * Used by PostList internally.
 */
import type { CollectionEntry } from "astro:content";
import PostMeta from "@/components/PostMeta.astro";
import PostCategory from "@/components/PostCategory.astro";
import { getPostUrl } from "@/utils/content.utils";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { category } = post.data;
const href = getPostUrl(post);
---

<div class="card card--interactive card--padded post-item">
  <a href={href} class="post-item__link">
    {post.data.title}
  </a>
  <div class="post-item__meta">
    {category && <PostCategory {category} />}
    <PostMeta published={post.data.published} />
  </div>
</div>