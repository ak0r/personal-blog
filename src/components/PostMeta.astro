---
/**
 * PostMeta — date, read time, places, and tags for posts.
 *
 * In list context (PostItem):  date only — "March 2nd", no icons
 * In post context (BlogLayout): places · date · read time, then tags on next line
 *
 * Layout (post context):
 *   Rajgad, Pune  ·  12 Mar 2024  ·  8 min
 *   #tag1  #tag2
 */
import { ordinalSuffix } from "@/utils/string.utils";
import Icon from "@/components/Icon.astro";

interface Props {
  published: Date;
  updated?:  Date;
  readTime?: string;
  tags?:     string[];
  places?:   string[];
}

const { published, updated, readTime, tags, places } = Astro.props;

const displayDate = updated ?? published;
const day   = displayDate.getDate();
const month = displayDate.toLocaleDateString("en-US", { month: "long" });
const year  = displayDate.getFullYear();

const dateShort = `${month} ${ordinalSuffix(day)}`;
const dateFull  = `${dateShort}, ${year}`;

const showFull    = !!readTime || (tags && tags.length > 0) || (places && places.length > 0);
const placesLabel = places?.join(', ') ?? null;
---

<div class="post-meta">

  {/* ── Main meta line: Rajgad, Pune · 12 Mar 2024 · 8 min ─────────── */}
  <div class="post-meta__line">

    {placesLabel && (
      <>
        <span class="post-meta__item post-meta__places">
          {placesLabel}
        </span>
        <span class="post-meta-sep" aria-hidden="true">·</span>
      </>
    )}

    <time class="post-meta__item" datetime={published.toISOString()}>
      {showFull && <Icon name="calendar" size={13} />}
      {updated && showFull && <span class="post-meta__updated-label">Updated</span>}
      {showFull ? dateFull : dateShort}
    </time>

    {readTime && (
      <>
        <span class="post-meta-sep" aria-hidden="true">·</span>
        <span class="post-meta__item">
          <Icon name="clock" size={13} />
          {readTime}
        </span>
      </>
    )}

  </div>

  {/* ── Tags line: #tag1  #tag2 ──────────────────────────────────────── */}
  {tags && tags.length > 0 && (
    <div class="post-meta__tags" aria-label="Tags">
      {tags.map((tag) => (
        <span class="post-tag">#{tag}</span>
      ))}
    </div>
  )}

  <slot />
</div>