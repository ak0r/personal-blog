---
/**
 * Tag — displays a tag as a plain badge.
 *
 * No link — tags are display-only metadata.
 * Filtering by tag happens on /travel/ and /tech/ via URL params.
 *
 * With count:    #tag (3)
 * Without count: #tag
 */

interface Props {
  tag: string;
  count?: number;
}

const { tag, count } = Astro.props;
---

<span class="badge badge--ghost badge--accent tag">
  <span>#{tag}</span>
  {count !== undefined && (
    <span class="tag-count badge__count">({count})</span>
  )}
</span>