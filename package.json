{
  "name": "astro-base",
  "type": "module",
  "version": "0.6.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "sync-template": "bash scripts/sync-template-local.sh",
    "sync-content": "bash scripts/sync-content-local.sh",
    "sync": "pnpm sync-template && pnpm sync-content",
    "sync-dry": "pnpm sync-template --dry-run && pnpm sync-content --dry-run",
    "dev": "pnpm sync && cd template && pnpm dev --host",
    "build": "cd template && pnpm build",
    "preview": "cd template && pnpm preview"
  }
}
