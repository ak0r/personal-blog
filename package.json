{
  "name": "astro-base",
  "type": "module",
  "version": "0.6.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "cd template && pnpm dev",
    "build": "cd template && pnpm build",
    "sync": "bash sync-content.sh",
    "sync:dry": "bash sync-content.sh --dry-run",
    "sync:lipi": "git fetch lipi && git log lipi/main --oneline -20",
    "sync:lipi:diff": "git diff lipi/main -- template/"
  }
}
